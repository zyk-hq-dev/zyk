# Hatchet (required for local dev)
HATCHET_CLIENT_TOKEN=your-token-here
HATCHET_HOST_PORT=localhost:7077

# Zyk server (optional for local dev)
# Port the MCP server + dashboard listens on (default: 3100)
PORT=3100
# External base URL workers use to reach the Zyk server.
# Local default: http://localhost:3100
# Railway: set to your zyk service public URL, e.g. https://<zyk>.up.railway.app
ZYK_WEBHOOK_BASE=
# Protects the MCP endpoint and dashboard. Leave blank to disable auth locally.
ZYK_API_KEY=

# Workflow secrets (add what your workflows need)
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
GITHUB_TOKEN=
STRIPE_SECRET_KEY=
